# Real Native product profile. Copy to data/107dashboard.env and replace USERNAME.
# Fixture fallback stays disabled so simulated jobs can never be mistaken for real Slurm jobs.
APP_ENV=production
APP_HOST=127.0.0.1
APP_PORT=8000
APP_LOG_LEVEL=INFO
SERVE_FRONTEND=true
FRONTEND_DIST_DIRECTORY=/home/scc/USERNAME/107dashboard/frontend/dist
DATABASE_URL=sqlite:////home/scc/USERNAME/107dashboard/data/dashboard.sqlite3
SLURM_DATA_SOURCE=native
DASHBOARD_OWNER=USERNAME
JOB_WORKSPACE_DIRECTORY=/home/scc/USERNAME/107dashboard/data/jobs
TEST_PROJECT_DIRECTORY=/home/scc/USERNAME/dashboard-test-projects
GIT_REPOSITORY_ROOT=/home/scc/USERNAME
GIT_REPOSITORY_SCAN_DEPTH=3
GIT_REPOSITORY_LIMIT=50
SLURM_COMMAND_TIMEOUT_SECONDS=10
SLURM_QUERY_CACHE_TTL_SECONDS=2
SLURM_MAX_JOBS=1000
NATIVE_SUBMISSION_ENABLED=true
NATIVE_LOGS_ENABLED=true
NATIVE_CANCEL_ENABLED=true
NATIVE_CLONE_ENABLED=true
NATIVE_MAX_ACTIVE_JOBS=2
DEMO_FALLBACK_ENABLED=false
