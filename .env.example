# Backend runtime
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
APP_LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# SQLite prototype database (keep runtime data outside tracked source files)
DATABASE_URL=sqlite:///./data/dashboard.sqlite3

# Frontend -> backend URL
VITE_API_BASE_URL=http://127.0.0.1:8000/api

# Slurm defaults verified on the target platform
SLURM_CLUSTER=training
SLURM_PARTITION=Students
SLURM_ACCOUNT=stu
SLURM_QOS=qos_stu_default
