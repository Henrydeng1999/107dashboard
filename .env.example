# Backend runtime
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
APP_LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SERVE_FRONTEND=false
FRONTEND_DIST_DIRECTORY=frontend/dist

# SQLite prototype database (relative paths are anchored to the repository root)
DATABASE_URL=sqlite:///./data/dashboard.sqlite3
# AI Provider keys are stored as private files here, never in SQLite or Git
AI_SECRET_DIRECTORY=data/secrets/ai

# Frontend -> backend URL
VITE_API_BASE_URL=http://127.0.0.1:8000/api

# Slurm data source: fixture locally; Native requires DASHBOARD_OWNER=id -un
SLURM_DATA_SOURCE=fixture
SLURM_FIXTURE_DIRECTORY=fixtures/slurm
FIXTURE_JOB_OUTPUT_DIRECTORY=fixtures/job-output
JOB_WORKSPACE_DIRECTORY=data/jobs
SLURM_COMMAND_TIMEOUT_SECONDS=10
SLURM_QUERY_CACHE_TTL_SECONDS=2
SLURM_MAX_JOBS=1000
DASHBOARD_OWNER=demo-user
NATIVE_SUBMISSION_ENABLED=false
# Single-worker competition limit; do not treat this as cross-process quota enforcement
NATIVE_MAX_ACTIVE_JOBS=1
NATIVE_LOGS_ENABLED=false
NATIVE_CANCEL_ENABLED=false
NATIVE_CLONE_ENABLED=false
# Native read failures may fall back to sanitized fixtures; all writes fail closed while active
DEMO_FALLBACK_ENABLED=false
DEMO_FALLBACK_COOLDOWN_SECONDS=30
DEMO_FALLBACK_OWNER=demo-user
SLURM_CLUSTER=training
SLURM_PARTITION=Students
SLURM_ACCOUNT=stu
SLURM_QOS=qos_stu_default
